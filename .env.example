# APEX — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git (it's in .gitignore)

# Required: Anthropic API key for APEX agent and benchmark
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Binance API credentials (for crypto tracker demo)
# Get keys at: https://www.binance.com/en/my/settings/api-management
# For development, use testnet keys: https://testnet.binance.vision
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Set to true to use Binance testnet (free, no real funds)
BINANCE_TESTNET=false
